# Copy to .env and fill in only when you're ready to talk to real providers.
# Everything is optional. Each service runs in dry_run mode when its credentials
# are missing — the DB and ledger still record full state.

# DATABASE_URL=sqlite:///data/finance.db
# DATABASE_URL=postgresql+psycopg2://finance:finance@localhost:5432/finance

# PAYPAL_BASE=https://api-m.sandbox.paypal.com
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_WEBHOOK_ID=

# PLAID_BASE=https://sandbox.plaid.com
# PLAID_CLIENT_ID=
# PLAID_SECRET=

# DWOLLA_BASE=https://api-sandbox.dwolla.com
# DWOLLA_KEY=
# DWOLLA_SECRET=
# DWOLLA_MASTER_FUNDING_SOURCE=
# DWOLLA_WEBHOOK_SECRET=

# PRINTIFY_KEY=
# PRINTFUL_KEY=

# Optional CRM bridge (server-to-server). Leave unset to run fully standalone.
# CRM_API_BASE_URL=https://api.example.com          # where PayPal-paid webhooks are relayed
# FINANCE_RELAY_SECRET=                              # shared HMAC secret with the CRM Worker
# CRM_JWT_SECRET=                                    # optional: verify operator JWTs
# FERNET_KEY=                                        # at-rest key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
